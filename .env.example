# Copy to .env and fill in. NEVER commit .env.

# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web application)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must exactly match an "Authorized redirect URI" on the OAuth client
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Random secret used to sign the session cookie (generate your own!)
SESSION_SECRET=change-me-to-a-long-random-string

# Neon Postgres connection string. Use the POOLED url (host contains "-pooler").
# e.g. postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Fernet key for encrypting stored tokens. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=generate-a-fernet-key

# Optional: only needed for local testing over plain http
OAUTHLIB_INSECURE_TRANSPORT=1
